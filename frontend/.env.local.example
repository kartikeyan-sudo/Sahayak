# Example env for local development
# Copy this to .env.local (do NOT commit) or set env vars in your shell
# Preferred API base variable (used across frontend API modules)
VITE_API_BASE_URL=http://localhost:5000
# Backward-compatible alias
VITE_API_BASE=http://localhost:5000
VITE_OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
# Optional: change model as needed
VITE_OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# Optional: custom OpenRouter base URL
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
